	<changeSet id="unsync-patient-1.0.0" author="ihmodule">
		<preConditions onFail="MARK_RAN">
			<not><tableExists tableName="unsync_patient"/></not>
		</preConditions>
		<comment>Patients not sent to central FHIR while published-config sync is disabled.</comment>
		<createTable tableName="unsync_patient">
			<column name="id" type="bigint(20)" autoIncrement="true">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="patient_uuid" type="varchar(38)">
				<constraints nullable="false" unique="true"/>
			</column>
		</createTable>
	</changeSet>

	<!-- Existing installs may have created patient_uuid as UNIQUE; drop it so duplicates are allowed. -->
	<!-- Liquibase 3.x (OpenMRS 2.4): indexExists does not support tableName; use sqlCheck for MySQL/MariaDB. -->
	<changeSet id="unsync-patient-drop-unique-patient-uuid-1.0.0" author="ihmodule" dbms="mysql,mariadb">
		<preConditions onFail="MARK_RAN">
			<sqlCheck expectedResult="1">
				SELECT COUNT(*) FROM INFORMATION_SCHEMA.STATISTICS
				WHERE TABLE_SCHEMA = DATABASE()
				AND TABLE_NAME = 'unsync_patient'
				AND INDEX_NAME = 'patient_uuid'
				AND NON_UNIQUE = 0
			</sqlCheck>
		</preConditions>
		<comment>Allow multiple unsync_patient rows per patient_uuid (no unique constraint).</comment>
		<dropIndex indexName="patient_uuid" tableName="unsync_patient"/>
	</changeSet>

	<changeSet id="ih-marker-last-id-1.0.0" author="ihmodule">
		<preConditions onFail="MARK_RAN">
			<not>
				<columnExists tableName="ih_marker" columnName="last_id"/>
			</not>
		</preConditions>
		<comment>Progress cursor for unsync_patient replay (UNSYNCED_PATIENT marker).</comment>
		<addColumn tableName="ih_marker">
			<column name="last_id" type="int(11)" defaultValueNumeric="0">
				<constraints nullable="true"/>
			</column>
		</addColumn>
	</changeSet>

	<!--
		Some databases have ih_marker.id as NOT NULL without AUTO_INCREMENT (e.g. manual DDL or older deploys).
		Hibernate native id generation omits id on INSERT; MySQL then raises "Field 'id' doesn't have a default value".
	-->
	<changeSet id="ih-marker-id-auto-increment-mysql-1.0.0" author="ihmodule" dbms="mysql,mariadb">
		<preConditions onFail="MARK_RAN">
			<sqlCheck expectedResult="1">
				SELECT COUNT(*) FROM INFORMATION_SCHEMA.COLUMNS
				WHERE TABLE_SCHEMA = DATABASE()
				AND TABLE_NAME = 'ih_marker'
				AND COLUMN_NAME = 'id'
				AND IFNULL(EXTRA, '') NOT LIKE '%auto_increment%'
			</sqlCheck>
		</preConditions>
		<comment>Ensure ih_marker.id is AUTO_INCREMENT for Hibernate-generated inserts.</comment>
		<sql>ALTER TABLE ih_marker MODIFY COLUMN id INT(11) NOT NULL AUTO_INCREMENT;</sql>
	</changeSet>

	<changeSet id="unsync-patient-status-1.0.0" author="ihmodule">
		<preConditions onFail="MARK_RAN">
			<not>
				<columnExists tableName="unsync_patient" columnName="status"/>
			</not>
		</preConditions>
		<comment>PENDING / COMPLETED / FAILED lifecycle for unsync_patient replay.</comment>
		<addColumn tableName="unsync_patient">
			<column name="status" type="varchar(32)" defaultValue="PENDING">
				<constraints nullable="false"/>
			</column>
		</addColumn>
	</changeSet>

</databaseChangeLog>