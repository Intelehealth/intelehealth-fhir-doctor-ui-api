<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="org.openmrs.module.ihmodule.api.patientexchange.validationrecord">
	<class name="FhirResourceValidationRecord" table="fhir_resource_validation_record">
		<id name="id" type="long" column="id">
			<generator class="assigned"/>
		</id>
		<property name="resourceType" type="string" column="resource_type" not-null="true"/>
		<property name="resourceLogicalId" type="string" column="resource_logical_id"/>
		<property name="outcome" type="string" column="outcome" not-null="true"/>
		<property name="message" type="text" column="message"/>
		<property name="payloadJson" type="text" column="payload_json"/>
		<property name="dateCreated" type="string" column="date_created"/>
		<property name="recordUuid" type="string" column="record_uuid" not-null="true"/>
	</class>
</hibernate-mapping>
