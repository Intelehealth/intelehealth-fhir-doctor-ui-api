<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="org.openmrs.module.ihmodule.api.patientexchange.model">
	<class name="IHMarker" table="ih_marker">
		<id name="id" type="int" column="id">
			<generator class="native"/>
		</id>
		<property name="name" type="string" column="name" length="255"/>
		<property name="lastSyncTime" type="string" column="last_sync_time" length="255"/>
	</class>
</hibernate-mapping>
