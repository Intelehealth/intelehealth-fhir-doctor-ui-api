<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="org.openmrs.module.ihmodule.api.patientexchange.sync">
	<class name="UnsyncPatient" table="unsync_patient">
		<id name="id" type="long" column="id">
			<generator class="native"/>
		</id>
		<property name="patientUuid" type="string" column="patient_uuid" not-null="true"/>
		<property name="status" type="string" column="status" not-null="true" length="32"/>
	</class>
</hibernate-mapping>
