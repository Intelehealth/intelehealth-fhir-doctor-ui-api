	</advice>
	 /AOP -->
	
	
	<!-- Required Privileges 
	<privilege>
		<name>Form Entry</name>
		<description>Allows user to access Form Entry pages/functions</description>
	</privilege>
	 /Required Privileges -->


	<globalProperty>
		<property>ihmodule.fhir.event.listener.enabled</property>
		<defaultValue>true</defaultValue>
		<description>
			Master toggle for async event-driven patient FHIR sync on PatientService.savePatient.
			When false, patient create/update save events do not trigger outbound FHIR sends.
		</description>
	</globalProperty>
	<globalProperty>
		<property>ihmodule.fhir.event.listener.create.enabled</property>
		<defaultValue>true</defaultValue>
		<description>
			When true and the master toggle is enabled, patient create events trigger outbound
			FHIR sync.
		</description>
	</globalProperty>
	<globalProperty>
		<property>ihmodule.fhir.event.listener.update.enabled</property>
		<defaultValue>true</defaultValue>
		<description>
			When true and the master toggle is enabled, patient update events trigger outbound
			FHIR sync.
		</description>
	</globalProperty>
	
