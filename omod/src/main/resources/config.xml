<?xml version="1.0" encoding="UTF-8"?>

<module configVersion="1.2">
	
	<!-- Base Module Properties -->
	<id>${project.parent.artifactId}</id>
	<name>${project.parent.name}</name>
	<version>${project.parent.version}</version>
	<package>org.openmrs.module.ihmodule</package>
	<author>proshanto</author>
	<description>
			${project.parent.description}
	</description>

	<activator>org.openmrs.module.ihmodule.APIfordoctorUIActivator</activator>
	
	<!-- <updateURL>https://modules.openmrs.org/modules/download/@MODULE_ID@/update.rdf</updateURL> -->
	<!-- /Base Module Properties -->
	
	<require_version>${openmrsPlatformVersion}</require_version>

	<require_modules>
		<require_module>org.openmrs.module.webservices.rest</require_module>
		<require_module>org.openmrs.module.fhir2</require_module>
	</require_modules>
	
	<!-- Extensions -->
	<extension>
		<point>org.openmrs.admin.list</point>
		<class>org.openmrs.module.ihmodule.extension.html.AdminList</class>
	</extension>

	<advice>
		<point>org.openmrs.api.PatientService</point>
		<class>org.openmrs.module.ihmodule.api.patientexchange.event.PatientEventListener</class>
	</advice>

	<aware_of_modules>
		<aware_of_module>org.openmrs.module.legacyui</aware_of_module>
	</aware_of_modules>
	
	<mappingFiles>
		configDataSyncModule.hbm.xml
		configFacility.hbm.xml
		dataExchangeAuditLog.hbm.xml
		externalAppointment.hbm.xml
		diagnosticReport.hbm.xml
		externalReferral.hbm.xml
		patientDataExchangeIHMarker.hbm.xml
		patientDataExchangeDataExchangeAuditLog.hbm.xml
		patientDataExchangeMpiDuplicateReviewCase.hbm.xml
		patientDataExchangeMpiDuplicateReviewCandidate.hbm.xml
		patientDataExchangeValidationRecord.hbm.xml
	</mappingFiles>
	<!-- AOP
	<advice>
		<point>org.openmrs.api.FormService</point>
